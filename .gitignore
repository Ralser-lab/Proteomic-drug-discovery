# Upload no tsvs or csvs
*.tsv
*.csv

# Ignore everything in .snakemake/
.snakemake/* 

# Ignore everything in data/ except placeholders/docs
data/*
!data/.gitkeep
!data/README.md

# Ignore everything in figures/ except placeholder
figures/*
!figures/.gitkeep

# Ignore everything in scoring_models/ except placeholder
scoring_models/*
!scoring_models/.gitkeep

# Ignore everything in log/ except placeholder; also ignore R history
log/*
!log/.gitkeep
log/.Rhistory

# macOS
*.DS_Store

# R specific files
*.Rhistory

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/

# Abstra (AI-powered process automation framework)
.abstra/

# Cursor editor
.cursorignore
.cursorindexingignore

# Ruff
.ruff_cache/

# PyPI config
.pypirc

# Visual Studio Code
# If you prefer, uncomment to ignore the entire folder:
# .vscode/

# PyCharm
# For a nuclear option (not recommended), uncomment:
# .idea/

